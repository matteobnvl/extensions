{
  "manifest_version": 3,
  "name": "Betclic AI",
  "version": "1.0",
  "description": "Analyse les cotes Betclic et génère 3 tickets via IA",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Betclic AI"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.betclic.fr/*",
        "*://*.betclic.com/*"
      ],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "permissions": [
    "activeTab",
    "tabs",
    "storage"
  ],
  "host_permissions": [
    "http://localhost/*"
  ]
}
